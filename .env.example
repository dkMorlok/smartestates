# Runtime
APP_ENV=dev
LOG_LEVEL=INFO
SENTRY_DSN=

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=realitni
POSTGRES_USER=realitni
POSTGRES_PASSWORD=realitni_dev_password
DATABASE_URL=postgresql+psycopg://realitni:realitni_dev_password@postgres:5432/realitni

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Object storage (MinIO locally; R2/S3 in prod)
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_RAW=raw-listings
S3_BUCKET_PHOTOS=listing-photos
S3_REGION=us-east-1

# Scraper
SCRAPER_USER_AGENT=RealitniSkener/0.1 (+contact@example.cz)
SREALITY_RATE_LIMIT_RPS=1.0
SREALITY_BASE_URL=https://www.sreality.cz

# Geocoding
# Optional self-hosted Nominatim. Leave unset to geocode from source GPS only.
# With the `geo` compose profile running: http://nominatim:8080
NOMINATIM_URL=
NOMINATIM_PASSWORD=nominatim_dev_password

# API
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000
